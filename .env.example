# Copy to ".env.local" and fill in. This file must stay free of real secrets.

NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase → Project Settings → API (JWT "anon" / "public" for supabase-js)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional: Devnet escrow receiver (base58) for Start Session transfers
NEXT_PUBLIC_ESCROW_WALLET=

# Optional: set to 1 if Next devtools / SegmentViewNode errors appear in the terminal (Next 15 + React 19)
# NEXT_DISABLE_DEVTOOLS=1

# =============================================================================
# M2M Oracle / backend — vehicle OEM & charger cloud APIs (SERVER ONLY)
# Never prefix these with NEXT_PUBLIC_. Load only in Node (API routes, workers).
# Register each integration in the vendor’s developer portal; names follow common
# OAuth 2.0 or API-key patterns. Adjust to match the exact docs for your tier.
# =============================================================================

# --- Tesla (Fleet API) — developer.tesla.com ---
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI=
# Regional fleet base, e.g. NA: https://fleet-api.prd.na.vn.cloud.tesla.com | EU: https://fleet-api.prd.eu.vn.cloud.tesla.com
TESLA_FLEET_API_BASE=

# --- Rivian (partner / connected APIs where available) ---
RIVIAN_CLIENT_ID=
RIVIAN_CLIENT_SECRET=
RIVIAN_API_BASE=

# --- Ford (Ford Developer / connected vehicle) ---
FORD_CLIENT_ID=
FORD_CLIENT_SECRET=
FORD_REDIRECT_URI=

# --- General Motors (GM developer program) ---
GM_CLIENT_ID=
GM_CLIENT_SECRET=
GM_REDIRECT_URI=

# --- Hyundai (Blue Link / connected developer program, region-specific) ---
HYUNDAI_CLIENT_ID=
HYUNDAI_CLIENT_SECRET=
HYUNDAI_REDIRECT_URI=

# --- Kia (Kia Connect developer program, region-specific) ---
KIA_CLIENT_ID=
KIA_CLIENT_SECRET=
KIA_REDIRECT_URI=

# --- BMW (BMW Connected API) ---
BMW_CLIENT_ID=
BMW_CLIENT_SECRET=
BMW_REDIRECT_URI=

# --- Mercedes-Benz (Mercedes-Benz / developers) ---
MERCEDES_CLIENT_ID=
MERCEDES_CLIENT_SECRET=
MERCEDES_REDIRECT_URI=

# --- Volkswagen Group (market-specific connected APIs) ---
VOLKSWAGEN_CLIENT_ID=
VOLKSWAGEN_CLIENT_SECRET=
VOLKSWAGEN_REDIRECT_URI=

# --- Volvo Cars API ---
VOLVO_CLIENT_ID=
VOLVO_CLIENT_SECRET=
VOLVO_REDIRECT_URI=

# --- Polestar (partner APIs where offered) ---
POLESTAR_CLIENT_ID=
POLESTAR_CLIENT_SECRET=
POLESTAR_API_BASE=

# --- Nissan (Nissan Connect / regional developer access) ---
NISSAN_CLIENT_ID=
NISSAN_CLIENT_SECRET=
NISSAN_REDIRECT_URI=

# --- ChargePoint (official / partner API credentials — format depends on product) ---
CHARGEPOINT_API_KEY=
CHARGEPOINT_API_SECRET=
CHARGEPOINT_API_BASE=

# --- Wallbox (myWallbox / Wallbox Cloud — JWT or Basic per current docs) ---
WALLBOX_EMAIL=
WALLBOX_PASSWORD=
# Optional if your integration uses long-lived tokens instead:
# WALLBOX_REFRESH_TOKEN=

# --- Tesla charging hardware (often same Fleet OAuth as vehicles; separate if your app splits them) ---
# TESLA_CLIENT_ID= (reuse above)

# --- Enel X (JuiceNet / Enel X Way API) ---
ENELX_API_KEY=
ENELX_API_BASE=

# --- EVBox (EVBox Connect / management API) ---
EVBOX_API_KEY=
EVBOX_ORGANIZATION_ID=
EVBOX_API_BASE=

# --- ABB (e-mobility / partner API) ---
ABB_API_KEY=
ABB_API_BASE=

# --- Siemens (connected charging / partner API) ---
SIEMENS_API_KEY=
SIEMENS_API_BASE=

# --- Schneider Electric (EVlink / partner API) ---
SCHNEIDER_API_KEY=
SCHNEIDER_API_BASE=

# --- Zaptec (Zaptec API / cloud token) ---
ZAPTEC_API_TOKEN=
ZAPTEC_API_BASE=

# --- FLO (FLO developer / network API) ---
FLO_API_KEY=
FLO_API_BASE=

# --- EO Charging (EO Cloud / API key) ---
EO_CHARGING_API_KEY=
EO_CHARGING_API_BASE=

# --- Hypervolt (Hypervolt cloud API) ---
HYPERVOLT_API_KEY=
HYPERVOLT_API_BASE=

# --- myenergi (hub / cloud API — format per myenergi documentation) ---
MYENERGI_API_KEY=
MYENERGI_HUB_SERIAL=
MYENERGI_API_BASE=

# --- Pod Point (Pod Point API / partner) ---
PODPOINT_API_KEY=
PODPOINT_API_BASE=

# --- Emporia (Emporia cloud API) ---
EMPORIA_API_KEY=
EMPORIA_API_BASE=

# --- Autel (Autel cloud / partner API) ---
AUTEL_API_KEY=
AUTEL_API_BASE=

# --- Blink (Blink Network / host API) ---
BLINK_API_KEY=
BLINK_API_BASE=

# =============================================================================
# M2M Oracle core (server only) — webhooks, signing, Solana RPC
# =============================================================================

# Base URL your charger OEMs call (e.g. https://api.yourdomain.com)
M2M_ORACLE_PUBLIC_BASE_URL=

# HMAC or shared secret to verify incoming charger webhooks (per-vendor headers vary)
M2M_CHARGER_WEBHOOK_SECRET=

# Optional: separate secrets per vendor if you rotate independently
# CHARGEPOINT_WEBHOOK_SECRET=
# WALLBOX_WEBHOOK_SECRET=

# JSON body signing / internal API (QR flow, mobile → oracle)
M2M_ORACLE_API_KEY=

# Solana — server-side RPC (never expose to browser; use dedicated key with limits)
SOLANA_RPC_URL=
# Optional websocket for subscriptions
SOLANA_RPC_WS_URL=

# Escrow program & treasury (base58 pubkeys; Devnet for V1)
SOLANA_ESCROW_PROGRAM_ID=
M2M_TREASURY_OR_ESCROW_PUBKEY=

# Keypair for oracle to sign transactions (base58 JSON array or path — prefer KMS in prod)
# ORACLE_KEYPAIR_PATH=./keys/oracle-devnet.json
ORACLE_KEYPAIR_JSON=

# Session / driver tokens (if you issue JWTs from API routes)
M2M_JWT_SECRET=
M2M_JWT_ISSUER=m2m-oracle

# Vercel Cron / internal job auth
CRON_SECRET=

# Rate limiting (Upstash Redis — optional)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Observability (optional)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
